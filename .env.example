# Database (SQLite for ingest_jobs persistence)
DATABASE_URL=sqlite+aiosqlite:///./jobs.db

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development

# OpenRouter (unified LLM gateway — same pattern as Q1)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=baai/bge-m3
OPENROUTER_APP_NAME=Semantic Document Search
OPENROUTER_APP_URL=http://localhost:8000

# Qdrant (cloud or local via docker-compose)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_VERSION=v1

# Feature flags
AI_FEATURES_ENABLED=true

# Build metadata (injected at deploy time)
GIT_SHA=dev
